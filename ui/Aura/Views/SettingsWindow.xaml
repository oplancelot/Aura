<Window x:Class="Aura.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aura Settings"
        Width="500" Height="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E2E">

    <Window.Resources>
        <!-- Dark theme styles -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#89B4FA"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Title -->
            <RowDefinition Height="Auto"/>  <!-- AI Engine -->
            <RowDefinition Height="Auto"/>  <!-- API Key -->
            <RowDefinition Height="Auto"/>  <!-- Target Language -->
            <RowDefinition Height="Auto"/>  <!-- Target Process -->
            <RowDefinition Height="*"/>     <!-- Spacer -->
            <RowDefinition Height="Auto"/>  <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="✨ Aura" FontSize="28" FontWeight="Bold" Foreground="#CBA6F7"/>
            <TextBlock Text="Real-time Game Voice Translation" FontSize="13" Foreground="#6C7086"/>
        </StackPanel>

        <!-- AI Engine Selection -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock Text="AI Translation Engine"/>
            <ComboBox x:Name="EngineComboBox" Margin="0,4,0,0">
                <ComboBoxItem Content="Gemini 2.5 Flash (Cloud)" IsSelected="True"/>
                <ComboBoxItem Content="SenseVoice-Small (Local)"/>
            </ComboBox>
        </StackPanel>

        <!-- API Key -->
        <StackPanel Grid.Row="2" Margin="0,0,0,16">
            <TextBlock Text="API Key (for cloud engines)"/>
            <TextBox x:Name="ApiKeyTextBox"
                     Margin="0,4,0,0"
                     PasswordChar="●"
                     MaxLength="256"/>
        </StackPanel>

        <!-- Target Language -->
        <StackPanel Grid.Row="3" Margin="0,0,0,16">
            <TextBlock Text="Translate To"/>
            <ComboBox x:Name="TargetLangComboBox" Margin="0,4,0,0">
                <ComboBoxItem Content="中文 (Chinese)" IsSelected="True" Tag="zh"/>
                <ComboBoxItem Content="English" Tag="en"/>
                <ComboBoxItem Content="日本語 (Japanese)" Tag="ja"/>
                <ComboBoxItem Content="한국어 (Korean)" Tag="ko"/>
                <ComboBoxItem Content="Français (French)" Tag="fr"/>
                <ComboBoxItem Content="Deutsch (German)" Tag="de"/>
                <ComboBoxItem Content="Español (Spanish)" Tag="es"/>
            </ComboBox>
        </StackPanel>

        <!-- Target Process -->
        <StackPanel Grid.Row="4" Margin="0,0,0,16">
            <TextBlock Text="Target Voice App"/>
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="ProcessComboBox" Grid.Column="0"/>
                <Button x:Name="RefreshButton" Grid.Column="1" Content="🔄" Margin="8,0,0,0"
                        Width="40" Click="OnRefreshProcesses"/>
            </Grid>
            <TextBlock Text="Select Discord, TeamSpeak, or another voice application"
                       FontSize="11" Foreground="#6C7086" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="StartButton" Content="▶ Start Translation" Click="OnStartClick"
                    Margin="0,0,12,0"/>
            <Button x:Name="StopButton" Content="⏹ Stop" Click="OnStopClick"
                    Background="#F38BA8" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>
