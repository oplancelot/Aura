<Window x:Class="Aura.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:l="clr-namespace:Aura.Localization"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Title="{Binding WindowTitle}"
        DataContext="{x:Static l:LanguageManager.Instance}"
        Width="540" Height="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Closing="OnWindowClosing">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Title -->
            <RowDefinition Height="Auto"/>  <!-- Target App -->
            <RowDefinition Height="Auto"/>  <!-- Translate To -->
            <RowDefinition Height="Auto"/>  <!-- Engine -->
            <RowDefinition Height="Auto"/>  <!-- Shortcuts -->
            <RowDefinition Height="Auto"/>  <!-- Update -->
            <RowDefinition Height="*"/>     <!-- Spacer -->
            <RowDefinition Height="Auto"/>  <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Title + Language Toggle -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Aura" FontSize="28" FontWeight="Bold" Foreground="#CBA6F7"/>
            <Button Grid.Column="2" Content="{Binding LangLabel}"
                    Width="72" Height="24" FontSize="11" Padding="0"
                    Background="{DynamicResource MaterialDesignPaper}"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="1" Margin="0,2,0,0"
                    Click="OnToggleLanguage"
                    ToolTip="{Binding LangTooltip}"/>
        </Grid>
        <TextBlock Grid.Row="0" Text="{Binding Subtitle}" FontSize="13"
                   Foreground="#6C7086" Margin="0,34,0,0"/>

        <!-- Target Process -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="{Binding TargetAppLabel}" FontWeight="SemiBold"/>
            <ComboBox x:Name="ProcessComboBox" Margin="0,4,0,0"/>
            <TextBlock Text="{Binding TargetAppHint}"
                       FontSize="11" Foreground="#6C7086" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Language → LLM (disabled) -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12" Opacity="0.5">
            <TextBlock Text="{Binding TranslateToLabel}" FontWeight="SemiBold"/>
            <ComboBox x:Name="TargetLangComboBox" Margin="0,4,0,0" IsEnabled="False">
                <ComboBoxItem Content="{Binding ChineseItem}" IsSelected="True" Tag="zh"/>
                <ComboBoxItem Content="{Binding EnglishItem}" Tag="en"/>
            </ComboBox>
            <TextBlock Text="{Binding TranslateToNote}"
                       FontSize="11" Foreground="#6C7086" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Engine -->
        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <TextBlock Text="{Binding EngineLabel}" FontWeight="SemiBold"/>
            <ComboBox x:Name="EngineComboBox" Margin="0,4,0,0"
                      SelectionChanged="OnEngineChanged">
                <ComboBoxItem Content="{Binding SenseVoiceItem}" IsSelected="True"/>
                <ComboBoxItem Content="{Binding GeminiItem}" IsEnabled="False"/>
            </ComboBox>
        </StackPanel>

        <!-- Shortcuts -->
        <StackPanel Grid.Row="4" Margin="0,0,0,12">
            <TextBlock Text="{Binding ControlsLabel}" FontWeight="SemiBold"/>
            <Border BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,6,0,0">
                <StackPanel>
                    <TextBlock Text="{Binding ToggleMode}" FontSize="12"
                               FontFamily="Consolas" Foreground="#A6E3A1"/>
                    <TextBlock Text="{Binding DragHint}" FontSize="11"
                               Foreground="#6C7086" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Update check -->
        <StackPanel Grid.Row="5" Margin="0,0,0,12">
            <TextBlock Text="{Binding UpdatesLabel}" FontWeight="SemiBold"/>
            <Border BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,6,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="UpdateStatusText" Grid.Column="0"
                               FontSize="12" Foreground="#6C7086"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"/>
                    <Button x:Name="CheckUpdateButton" Grid.Column="1"
                            Content="{Binding CheckButton}" Padding="16,4"
                            Click="OnCheckUpdateClick"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </StackPanel>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="StartButton" Content="{Binding StartButton}" Click="OnStartClick"
                    Margin="0,0,12,0"/>
            <Button x:Name="StopButton" Content="{Binding StopButton}" Click="OnStopClick"
                    Background="#F38BA8" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>
