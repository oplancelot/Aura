<Window x:Class="Aura.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Title="Aura Settings"
        Width="540" Height="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Title -->
            <RowDefinition Height="Auto"/>  <!-- Target App -->
            <RowDefinition Height="Auto"/>  <!-- Translate To -->
            <RowDefinition Height="Auto"/>  <!-- Engine -->
            <RowDefinition Height="Auto"/>  <!-- Update -->
            <RowDefinition Height="*"/>     <!-- Spacer -->
            <RowDefinition Height="Auto"/>  <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Aura" FontSize="28" FontWeight="Bold" Foreground="#CBA6F7"/>
            <TextBlock Text="Real-time Game Voice Transcription" FontSize="13" Foreground="#6C7086"/>
        </StackPanel>

        <!-- Target Process -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Target App" FontWeight="SemiBold"/>
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="ProcessComboBox" Grid.Column="0"/>
                <Button x:Name="RefreshButton" Grid.Column="1" Content="🔄" Margin="8,0,0,0"
                        Width="40" Click="OnRefreshProcesses"/>
            </Grid>
            <TextBlock Text="Select Edge, Chrome, VLC, Discord, or Teams — or use Self Test (PID 0)"
                       FontSize="11" Foreground="#6C7086" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Language (cloud-only, disabled) -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12" Opacity="0.5">
            <TextBlock Text="Translate To" FontWeight="SemiBold"/>
            <ComboBox x:Name="TargetLangComboBox" Margin="0,4,0,0" IsEnabled="False">
                <ComboBoxItem Content="Chinese" IsSelected="True" Tag="zh"/>
                <ComboBoxItem Content="English" Tag="en"/>
            </ComboBox>
            <TextBlock Text="Cloud-only — currently local-only mode"
                       FontSize="11" Foreground="#6C7086" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Engine -->
        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <TextBlock Text="Engine" FontWeight="SemiBold"/>
            <ComboBox x:Name="EngineComboBox" Margin="0,4,0,0"
                      SelectionChanged="OnEngineChanged">
                <ComboBoxItem Content="SenseVoice-Small (Local, offline)" IsSelected="True"/>
                <ComboBoxItem Content="Gemini 2.5 Flash (Cloud)" IsEnabled="False"/>
            </ComboBox>
        </StackPanel>

        <!-- Update check -->
        <StackPanel Grid.Row="4" Margin="0,0,0,12">
            <TextBlock Text="Updates" FontWeight="SemiBold"/>
            <Border BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,6,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="UpdateStatusText" Grid.Column="0"
                               Text="Check for new version..."
                               FontSize="12" Foreground="#6C7086"
                               VerticalAlignment="Center"/>
                    <Button x:Name="CheckUpdateButton" Grid.Column="1"
                            Content="Check" Padding="16,4"
                            Click="OnCheckUpdateClick"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </StackPanel>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="StartButton" Content="▶ Start Translation" Click="OnStartClick"
                    Margin="0,0,12,0"/>
            <Button x:Name="StopButton" Content="⏹ Stop" Click="OnStopClick"
                    Background="#F38BA8" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>
